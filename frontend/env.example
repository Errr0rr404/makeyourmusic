# Frontend-only environment variables.
# Do not put DATABASE_URL, JWT secrets, provider secrets, or private API keys in
# frontend/.env*. Keep those in backend/.env or your deployment platform's
# backend service settings.

# Backend API URL used by browser code. Prefer the same-origin /api proxy so
# auth cookies stay first-party. Set INTERNAL_API_URL on the frontend service
# to point that proxy at the backend.
NEXT_PUBLIC_API_URL=/api

# Server-side target for next.config.mjs rewrites.
INTERNAL_API_URL=https://your-backend.example.com/api

# Socket.io URL. Optional; derive this from NEXT_PUBLIC_API_URL in app code
# where possible.
NEXT_PUBLIC_SOCKET_URL=https://your-backend.example.com

# WebSocket URL. Optional.
NEXT_PUBLIC_WS_URL=wss://your-backend.example.com

# Publishable Stripe key only. Secret Stripe keys belong in the backend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Error reporting. These values are public client config.
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_ERROR_REPORTING_ENDPOINT=https://your-api.com/errors

# Site URL for metadata, sitemap, and canonical URLs.
NEXT_PUBLIC_SITE_URL=https://your-site.com

# ─── Phase 0+ env vars added across roadmap sweeps ────────

# PostHog analytics. When NEXT_PUBLIC_POSTHOG_KEY is unset, the analytics
# shim still buffers events but never flushes — so absent config is safe.
# Sign up at https://posthog.com/ and use the project's "phc_..." key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Apple Universal Links + App Clip association (Phase 3). Read by the
# /.well-known/apple-app-site-association route. APPLE_TEAM_ID is the 10-char
# team identifier from the Apple Developer portal; the bundle ids match
# mobile/app.json (parent app) and the App Clip target you create in Xcode.
APPLE_TEAM_ID=
IOS_BUNDLE_ID=com.worldofz.makeyourmusic
IOS_APPCLIP_BUNDLE_ID=com.worldofz.makeyourmusic.Clip

# Android Digital Asset Links (Phase 3). Read by the /.well-known/assetlinks.json
# route. SHA256 fingerprint comes from `keytool -list -v -keystore <jks> -alias <alias>` —
# paste the colon-separated hex string. Comma-separated to list multiple keys.
ANDROID_PACKAGE_NAME=com.makeyourmusic.app
ANDROID_SHA256_FINGERPRINT=

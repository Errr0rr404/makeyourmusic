# Backend API URL (Required for Netlify deployment)
# Set this to your Railway backend URL
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app/api

# Socket.io URL (Optional - will derive from API URL if not set)
NEXT_PUBLIC_SOCKET_URL=https://your-railway-backend.up.railway.app

# WebSocket URL (Optional - will derive from API URL if not set)
NEXT_PUBLIC_WS_URL=wss://your-railway-backend.up.railway.app

# Database
# IMPORTANT: Use sslmode=verify-full for security. The code will automatically normalize
# deprecated SSL modes (prefer, require, verify-ca) to verify-full to silence warnings.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=verify-full

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# OpenAI (optional)
OPENAI_API_KEY=sk-...

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Environment
NODE_ENV=development

# Stripe Publishable Key (get from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Terminal (optional - for POS card readers)
# Get location ID from Stripe Dashboard → Terminal → Locations
# NEXT_PUBLIC_STRIPE_TERMINAL_LOCATION_ID=tmloc_xxxxx

# Error Reporting (optional)
# Sentry DSN for error tracking (get from sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Custom error reporting endpoint (alternative to Sentry)
# NEXT_PUBLIC_ERROR_REPORTING_ENDPOINT=https://your-api.com/errors

# Site URL (optional - for sitemap and SEO)
# NEXT_PUBLIC_SITE_URL=https://your-site.com

{
   "name": "makeyourmusic-backend",
   "version": "1.0.0",
   "description": "MakeYourMusic - Backend API",
   "main": "dist/server.js",
   "scripts": {
      "postinstall": "bash generate-prisma.sh",
      "dev": "nodemon --exec ts-node src/server.ts",
      "build": "tsc",
      "start": "node dist/server.js",
      "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
      "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
      "prisma:deploy": "prisma migrate deploy --schema=../prisma/schema.prisma",
      "prisma:studio": "prisma studio --schema=../prisma/schema.prisma",
      "prisma:seed": "ts-node --transpile-only scripts/create-dummy-data.ts",
      "seed": "ts-node --transpile-only scripts/create-dummy-data.ts",
      "seed:massive": "ts-node --transpile-only scripts/seed-massive.ts",
      "create-admin": "ts-node --transpile-only scripts/create-admin.ts"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "type": "commonjs",
   "dependencies": {
      "@prisma/adapter-pg": "^6.8.2",
      "@prisma/client": "^6.8.2",
      "@sentry/node": "^10.51.0",
      "argon2": "^0.44.0",
      "axios": "^1.9.0",
      "cloudinary": "^2.5.1",
      "cookie-parser": "^1.4.7",
      "cors": "^2.8.5",
      "date-fns": "^4.1.0",
      "dotenv": "^16.5.0",
      "express": "^5.1.0",
      "express-rate-limit": "^7.5.0",
      "express-validator": "^7.2.1",
      "firebase-admin": "^13.8.0",
      "helmet": "^8.1.0",
      "jose": "^5.10.0",
      "multer": "^2.0.2",
      "pg": "^8.16.0",
      "prisma": "^6.8.2",
      "socket.io": "^4.8.1",
      "stripe": "^18.1.0",
      "winston": "^3.18.0",
      "zod": "^3.25.23"
   },
   "devDependencies": {
      "@types/cookie-parser": "^1.4.8",
      "@types/cors": "^2.8.18",
      "@types/express": "^5.0.2",
      "@types/multer": "^1.4.12",
      "@types/node": "^22.15.21",
      "@types/pg": "^8.11.14",
      "@types/validator": "^13.15.10",
      "nodemon": "^3.1.10",
      "ts-node": "^10.9.2",
      "typescript": "^5.8.3"
   },
   "overrides": {
      "uuid": "14.0.0"
   }
}

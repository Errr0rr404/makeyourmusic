{
  "name": "makeyourplatform-backend",
  "version": "1.0.0",
  "description": "MakeYourPlatform backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=../prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../prisma/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:erp": "ts-node prisma/seed-comprehensive-erp.ts",
    "seed:all": "ts-node prisma/seed.ts",
    "create-admin": "ts-node --transpile-only scripts/create-admin.ts",
    "update-passwords": "ts-node --transpile-only scripts/update-passwords.ts",
    "create-manager": "ts-node --transpile-only scripts/create-manager.ts",
    "create-mastermind": "ts-node --transpile-only scripts/create-mastermind.ts",
    "create-dummy-data": "ts-node --transpile-only scripts/create-dummy-data.ts",
    "create-employee": "ts-node --transpile-only scripts/create-employee.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.17.1",
    "prisma": "^7.2.0",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@types/validator": "^13.15.10",
    "@types/winston": "^2.4.4",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}

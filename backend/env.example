# Database
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL service
# For local: Use your Neon DB or local PostgreSQL connection string
# IMPORTANT: Use sslmode=verify-full for security. The code will automatically normalize
# deprecated SSL modes (prefer, require, verify-ca) to verify-full to silence warnings.
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=verify-full

# JWT Secrets (MUST be at least 32 characters long)
# Generate secure secrets for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Data Encryption Key (Optional - for additional data encryption)
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for encrypting sensitive user data at rest (emails, phone numbers, addresses)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-optional-for-extra-security

# Frontend URL (comma-separated for multiple origins)
# For production: https://your-frontend-domain.netlify.app
# For Railway: https://your-railway-backend-url.up.railway.app (if serving frontend)
FRONTEND_URL=http://localhost:3000

# Backend URL (optional, defaults to FRONTEND_URL if not set)
# For Railway: https://your-backend-service.up.railway.app
BACKEND_URL=http://localhost:3001

# Cloudinary (Required for image uploads in admin panel)
# Sign up at https://cloudinary.com to get your credentials
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# OpenAI API (Required for AI Chatbot)
# Sign up at https://platform.openai.com/ to get your API key
OPENAI_API_KEY=your_openai_api_key_here

# MiniMax AI (music + lyric + video generation)
# Sign up at https://platform.minimax.io/ to get your API key + group ID
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_MUSIC_MODEL=music-2.6-free
MINIMAX_CHAT_MODEL=MiniMax-Text-01
MINIMAX_VIDEO_MODEL=video-01

# AI generation daily limits (per user)
AI_GEN_DAILY_FREE_LIMIT=5
AI_GEN_DAILY_PREMIUM_LIMIT=100

# Email service (optional — defaults to console logging in dev)
# Choose ONE provider: Resend, SendGrid, or SMTP
# Resend: https://resend.com/
RESEND_API_KEY=
# SendGrid: https://sendgrid.com/
SENDGRID_API_KEY=
# SMTP: any provider (requires `npm i nodemailer` in backend/)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=Morlo.ai <no-reply@morlo.ai>

# Server Configuration
NODE_ENV=development
PORT=3001

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Payment Gateway
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Amazon Pay (Optional)
AMAZON_PAY_MERCHANT_ID=your_amazon_merchant_id
AMAZON_PAY_ACCESS_KEY=your_amazon_access_key
AMAZON_PAY_SECRET_KEY=your_amazon_secret_key
AMAZON_PAY_MODE=sandbox

# bKash (Bangladesh - Optional)
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_MODE=sandbox

# Nagad (Bangladesh - Optional)
NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_NUMBER=your_nagad_merchant_number
NAGAD_PUBLIC_KEY=your_nagad_public_key
NAGAD_PRIVATE_KEY=your_nagad_private_key
NAGAD_MODE=sandbox
# Client IP for Nagad API (optional, defaults to 127.0.0.1)
NAGAD_CLIENT_IP=127.0.0.1

# Rocket (Bangladesh - Optional)
ROCKET_MERCHANT_ID=your_rocket_merchant_id
ROCKET_MERCHANT_KEY=your_rocket_merchant_key
ROCKET_MERCHANT_NUMBER=your_rocket_merchant_number
ROCKET_MODE=sandbox

# Crypto Payments (Bitcoin & Ethereum - Optional)
# Enable crypto payments
CRYPTO_PAYMENTS_ENABLED=false

# Coinbase Commerce API (Recommended for crypto payments)
# Sign up at: https://commerce.coinbase.com/
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_coinbase_commerce_webhook_secret

# Crypto Payment Settings
# Number of blockchain confirmations required before payment is considered complete
BITCOIN_REQUIRED_CONFIRMATIONS=3
ETHEREUM_REQUIRED_CONFIRMATIONS=12

# ─── Phase 1+ env vars added across roadmap sweeps ────────

# Stem separation (Replicate / Demucs htdemucs). Without these, the stems UI
# returns "stem separation not configured". Pin DEMUCS_VERSION to a 64-hex
# Replicate version id (no fabricated default).
REPLICATE_API_TOKEN=
REPLICATE_DEMUCS_VERSION=

# Auto preview-clip (vertical Hailuo video) for new tracks.
# AUTO_PREVIEW_VIDEO=1 turns on the in-line kick-off + cron backfill.
# AUTOCLIP_BACKFILL_PER_TICK caps how many backfill jobs each cron tick fires.
AUTO_PREVIEW_VIDEO=
AUTOCLIP_BACKFILL_PER_TICK=5

# Free-tier audio outro watermark. When set, free users downloading audio
# get a 2s "Made with MakeYourMusic" splice; Premium + track owner stay clean.
# Upload the outro to Cloudinary as a video resource and paste its public_id here.
MYM_OUTRO_AUDIO_PUBLIC_ID=

# Cron tick (trending, party / dj sweeps, mixtapes, payouts, etc.). Disabled
# by default in dev so local runs stay quiet. Set to 1 in production.
RUN_CRON=

# Platform fee in basis points. 1500 = 15%. Used by sync licenses, stem
# purchases, marketplace, and tip flows.
PLATFORM_FEE_BPS=1500

# Public-API key + OAuth bearer token HMAC secret. Falls back to ENCRYPTION_KEY
# when unset. Both ApiKey.keyHash and OAuthGrant.accessTokenHash are derived
# via this secret — rotating it invalidates every issued key/token at once.
API_KEY_HMAC_SECRET=

# Admin panel password gate. The /admin/* surfaces require this PLUS a valid
# user JWT with role=ADMIN. Stored in env (not the DB) so it can be rotated
# without a deploy if a session leaks.
ADMIN_PANEL_PASSWORD=

# JWT issuer / audience claims. Defaults are fine; override only if you run
# multiple deployments that need to disambiguate tokens.
JWT_ISSUER=makeyourmusic
JWT_AUDIENCE=makeyourmusic-api

# Sentry error tracking. When unset, the Sentry SDK is a no-op.
SENTRY_DSN=

# Discord bot (Phase 3). Without these, /api/integrations/discord/interactions
# returns 401 to every request (signature verification fails). Get the public
# key + application id from Discord Developer Portal → General Information.
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
# Optional ApiKey.id used for unlinked Discord users so the /music create
# command still works before they link a MakeYourMusic account.
DISCORD_FREE_API_KEY_ID=

# Firebase Admin (server-side OAuth verification). Optional. When unset, the
# Firebase-exchange auth flow returns "social sign-in not configured". Either
# provide the JSON inline OR put the service account at
# backend/firebase-service-account.json (gitignored).
FIREBASE_SERVICE_ACCOUNT=

# Distribution partner integrations (Phase 3 — gated, not yet wired).
# Set DISTROKID_API_KEY (or TUNECORE_API_KEY) and the wizard exposes the
# "Submit via DistroKid" path; otherwise everything routes through the
# manual ops queue at /admin/distributions.
DISTROKID_API_KEY=
TUNECORE_API_KEY=

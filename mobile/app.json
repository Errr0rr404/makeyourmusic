{
  "expo": {
    "name": "Morlo",
    "slug": "morlo",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "morlo",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.morlo.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "Morlo needs microphone access to record audio.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["morlo"]
          }
        ]
      },
      "associatedDomains": ["applinks:morlo.ai"],
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ai.morlo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "morlo.ai",
              "pathPrefix": "/track"
            },
            {
              "scheme": "https",
              "host": "morlo.ai",
              "pathPrefix": "/agent"
            },
            {
              "scheme": "https",
              "host": "morlo.ai",
              "pathPrefix": "/genre"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8b5cf6"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/your-project-id",
      "enabled": true,
      "fallbackToCacheTimeout": 5000
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

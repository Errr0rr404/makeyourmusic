{
  "name": "makeyourplatform",
  "version": "1.0.0",
  "description": "Full-stack e-commerce platform",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "prisma:generate": "cd backend && npm run prisma:generate",
    "prisma:migrate": "cd backend && npm run prisma:migrate",
    "prisma:seed": "cd backend && npm run prisma:seed",
    "clean": "./scripts/cleanup.sh",
    "clean:logs": "rm -f backend/logs/*.log && touch backend/logs/.gitkeep",
    "clean:dist": "rm -rf backend/dist frontend/.next",
    "clean:all": "npm run clean && rm -rf node_modules frontend/node_modules backend/node_modules"
  },
  "keywords": [
    "ecommerce",
    "template",
    "nextjs",
    "express",
    "stripe"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^7.2.0"
  },
  "devDependencies": {
    "@prisma/config": "^7.2.0",
    "dotenv": "^17.2.3",
    "prisma": "^7.2.0"
  },
  "directories": {
    "doc": "docs"
  },
  "type": "commonjs"
}

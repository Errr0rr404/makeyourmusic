{
  "name": "makeyourmusic",
  "version": "1.0.0",
  "description": "MakeYourMusic - AI-Generated Content Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "dev:mobile": "cd mobile && npx expo start",
    "build:mobile:ios": "cd mobile && eas build --platform ios",
    "build:mobile:android": "cd mobile && eas build --platform android",
    "build:mobile:all": "cd mobile && eas build --platform all"
  },
  "keywords": [
    "ai-music",
    "ai-generated",
    "streaming",
    "platform",
    "makeyourmusic"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "prisma": "^6.8.2",
    "typescript-eslint": "^8.56.1"
  },
  "type": "commonjs"
}

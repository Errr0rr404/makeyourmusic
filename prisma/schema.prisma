// MakeYourMusic - AI-Generated Content Platform
// Prisma Schema

generator client {
  provider      = "prisma-client-js"
  output        = "../frontend/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

generator clientBackend {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  LISTENER
  AGENT_OWNER
  ADMIN
}

enum SubscriptionTier {
  FREE
  CREATOR
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum PlaylistAccessTier {
  PUBLIC
  PRIVATE
  PAID
}

enum ConnectAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISCONNECTED
}

enum TipStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ChannelSubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum TrackStatus {
  PROCESSING
  ACTIVE
  REMOVED
  FLAGGED
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum NotificationType {
  NEW_TRACK
  NEW_FOLLOWER
  TRACK_LIKED
  COMMENT
  SYSTEM
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GenerationKind {
  MUSIC
  VIDEO
}

enum TakedownStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum SyncLicenseStatus {
  PENDING
  PAID
  REFUNDED
  REVOKED
}

enum DistributionStatus {
  PENDING
  SUBMITTED
  LIVE
  REJECTED
  TAKEDOWN
}

enum StemStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum PayoutStatus {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum ClipVisibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum ClipStatus {
  PROCESSING
  READY
  REMOVED
  FLAGGED
}

enum ListeningPartyStatus {
  ACTIVE
  ENDED
}

enum MarketplaceListingType {
  SAMPLE_PACK
  PROMPT_PRESET
}

enum MarketplaceListingStatus {
  DRAFT
  ACTIVE
  REMOVED
}

enum MarketplacePurchaseStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum DjSessionStatus {
  LIVE
  PAUSED
  ENDED
}

enum OAuthAppStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

// ─── Core Models ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  username     String   @unique
  displayName  String?  @map("display_name")
  avatar       String?
  bio          String?
  role         UserRole @default(LISTENER)

  // OAuth / Firebase Auth (null for email/password users)
  firebaseUid  String? @unique @map("firebase_uid")
  authProvider String? @map("auth_provider")

  // Email verification
  emailVerified            Boolean   @default(false) @map("email_verified")
  emailVerifiedAt          DateTime? @map("email_verified_at")
  emailVerificationToken   String?   @unique @map("email_verification_token")
  emailVerificationExpires DateTime? @map("email_verification_expires")

  // Password reset
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")

  // Magic-link sign-in (one-shot, ~15min). Token stored hashed; the raw
  // token is mailed and exchanged for an access token via /auth/magic-link/verify.
  magicLinkToken   String?   @unique @map("magic_link_token")
  magicLinkExpires DateTime? @map("magic_link_expires")

  // Email notification preferences
  emailFollowerAlert Boolean @default(true) @map("email_follower_alert")
  emailLikeAlert     Boolean @default(false) @map("email_like_alert")
  emailCommentAlert  Boolean @default(true) @map("email_comment_alert")
  emailDigestWeekly  Boolean @default(true) @map("email_digest_weekly")
  emailMarketing     Boolean @default(false) @map("email_marketing")

  // Preferred locale for emails / notifications / push (BCP-47 short, e.g. "en", "es", "ja").
  // Frontend mirrors via the locale-prefixed URL; this is the source of truth for
  // server-rendered content the user receives outside the SPA.
  locale String? @default("en")

  // Bumped on logout / password change to invalidate all outstanding refresh tokens
  tokenVersion Int @default(0) @map("token_version")

  // Referral program — each user gets a unique short code; signup with ?ref=
  // captures referredById. Referrer earns 10% of referee creator earnings for
  // 12 months from signup (window enforced in code).
  referralCode String? @unique @map("referral_code")
  referredById String? @map("referred_by_id")
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("UserReferrals")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agents                     AiAgent[]
  playlists                  Playlist[]
  likes                      Like[]
  comments                   Comment[]
  follows                    Follow[]
  plays                      Play[]
  shares                     Share[]
  downloads                  Download[]
  subscription               Subscription?
  notifications              Notification[]
  reports                    Report[]
  musicGenerations           MusicGeneration[]
  videoGenerations           VideoGeneration[]
  pushTokens                 PushToken[]
  connectAccount             ConnectAccount?
  tipsSent                   Tip[]                 @relation("TipsSent")
  tipsReceived               Tip[]                 @relation("TipsReceived")
  channelSubsAsFan           ChannelSubscription[] @relation("ChannelSubsAsFan")
  channelSubsAsCreator       ChannelSubscription[] @relation("ChannelSubsAsCreator")
  syncLicensesPurchased      SyncLicense[]         @relation("SyncLicensePurchaser")
  takedownsFiled             Takedown[]
  apiKeys                    ApiKey[]
  referralEarningsAsReferrer ReferralEarning[]     @relation("ReferralEarningReferrer")
  referralEarningsAsSource   ReferralEarning[]     @relation("ReferralEarningSource")
  clips                      Clip[]
  clipLikes                  ClipLike[]
  clipComments               ClipComment[]
  clipShares                 ClipShare[]
  mixtapes                   UserMixtape[]
  collabPayoutsFrom          CollabPayout[]        @relation("CollabPayoutsFrom")
  collabPayoutsTo            CollabPayout[]        @relation("CollabPayoutsTo")
  partiesHosted              ListeningParty[]      @relation("PartiesHosted")
  partyMemberships           ListeningPartyMember[] @relation("PartyMembers")
  marketplaceListings        MarketplaceListing[]  @relation("MarketplaceListings")
  marketplacePurchases       MarketplacePurchase[] @relation("MarketplacePurchases")
  discordIntegrations        DiscordIntegration[]  @relation("DiscordIntegrations")
  djSessionsHosted           DjSession[]           @relation("DjSessionsHosted")
  oauthAppsOwned             OAuthApp[]            @relation("OAuthAppsOwned")
  oauthGrantsAuthorized      OAuthGrant[]          @relation("OAuthGrantsAuthorized")

  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@index([emailVerificationToken])
  @@index([passwordResetToken])
  @@index([magicLinkToken])
  @@index([referralCode])
  @@index([referredById])
  @@map("users")
}

model PushToken {
  id         String   @id @default(cuid())
  token      String   @unique
  platform   String // "ios" | "android" | "web"
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model AiAgent {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  avatar     String?
  coverImage String?     @map("cover_image")
  bio        String?
  status     AgentStatus @default(ACTIVE)

  // AI Generation config
  aiModel   String? @map("ai_model")
  apiKeyEnc String? @map("api_key_enc") // encrypted API key for external services
  genConfig Json?   @map("gen_config") // JSON config for generation params

  // Stats (denormalized for performance)
  totalPlays    Int @default(0) @map("total_plays")
  totalLikes    Int @default(0) @map("total_likes")
  followerCount Int @default(0) @map("follower_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ownerId          String              @map("owner_id")
  owner            User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks           Track[]
  albums           Album[]
  genres           AiAgentGenre[]
  followers        Follow[]
  earnings         AgentEarning[]
  musicGenerations MusicGeneration[]
  collaborations   TrackCollaborator[]

  @@index([ownerId])
  @@index([status])
  @@index([followerCount(sort: Desc)])
  @@index([totalPlays(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("ai_agents")
}

model Genre {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  color String? // hex color for UI

  tracks Track[]
  agents AiAgentGenre[]

  @@index([name])
  @@map("genres")
}

model AiAgentGenre {
  agentId String  @map("agent_id")
  genreId String  @map("genre_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  genre   Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([agentId, genreId])
  @@map("ai_agent_genres")
}

model Track {
  id       String      @id @default(cuid())
  title    String
  slug     String      @unique
  duration Int // duration in seconds
  audioUrl String      @map("audio_url")
  coverArt String?     @map("cover_art")
  status   TrackStatus @default(PROCESSING)

  // Visibility
  isPublic Boolean @default(true) @map("is_public")

  // Metadata
  mood   String?
  tags   String[] @default([])
  bpm    Int?
  key    String? // musical key (e.g. "C minor")
  lyrics String?  @db.Text

  // AI Attribution
  aiModel  String? @map("ai_model") // which AI model generated it
  aiPrompt String? @map("ai_prompt") // the prompt used

  // Stats (denormalized)
  playCount     Int @default(0) @map("play_count")
  likeCount     Int @default(0) @map("like_count")
  shareCount    Int @default(0) @map("share_count")
  downloadCount Int @default(0) @map("download_count")

  // Trending score — recomputed periodically by a cron job using a
  // Hacker-News-style decay so freshness is rewarded. Indexed for ORDER BY.
  trendingScore     Float    @default(0) @map("trending_score")
  trendingUpdatedAt DateTime @default(now()) @map("trending_updated_at")

  // Recommendation features. featureVector is a fixed-length numeric
  // representation derived from genre/mood/energy/era/bpm/tags; cosine
  // similarity over this powers "similar tracks", radio, and recommendations.
  // featureVersion lets us re-embed only stale rows after vector schema changes.
  featureVector  Float[] @default([]) @map("feature_vector")
  featureVersion Int     @default(0) @map("feature_version")

  // Sync licensing — when licenseable=true, listeners can buy a one-time
  // commercial-use license. Stored as an integer cents price; the actual
  // Stripe Price is created lazily on first checkout.
  licenseable       Boolean @default(false)
  licensePriceCents Int?    @map("license_price_cents")
  licenseCurrency   String? @default("usd") @map("license_currency")

  // DMCA takedown state. PENDING/ACCEPTED hides the track from listings.
  takedownStatus TakedownStatus? @map("takedown_status")
  takedownReason String?         @map("takedown_reason") @db.Text

  // Parent track — set when this track was created via section regeneration
  // or song extension from another track. Provides a lineage for analytics.
  parentTrackId String? @map("parent_track_id")
  parentTrack   Track?  @relation("TrackLineage", fields: [parentTrackId], references: [id], onDelete: SetNull)
  derivedTracks Track[] @relation("TrackLineage")

  // 15s vertical preview video used for TikTok/Reels share + embed previews.
  previewVideoUrl String? @map("preview_video_url")

  // Owner-published full music video. Distinct from previewVideoUrl (auto-generated 6s
  // clip) — this is the long-form music video the owner kicked off via the
  // /api/ai/music-video/:trackId endpoint. Surfaced as the hero on the track page.
  musicVideoUrl String? @map("music_video_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  genreId String? @map("genre_id")
  genre   Genre?  @relation(fields: [genreId], references: [id], onDelete: SetNull)
  albumId String? @map("album_id")
  album   Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)

  video             Video?
  likes             Like[]
  comments          Comment[]
  plays             Play[]
  shares            Share[]
  downloads         Download[]
  playlistTracks    PlaylistTrack[]
  reports           Report[]
  generations       MusicGeneration[]
  collaborators     TrackCollaborator[]
  stems             TrackStems?
  takedowns         Takedown[]
  syncLicenses      SyncLicense[]
  distributions     TrackDistribution[]
  clips             Clip[]
  tips              Tip[]
  videoGenerations  VideoGeneration[]   @relation("TrackVideoGenerations")
  collabPayouts     CollabPayout[]
  partiesPlaying    ListeningParty[]    @relation("PartyCurrentTrack")

  @@index([agentId])
  @@index([genreId])
  @@index([albumId])
  @@index([status])
  @@index([isPublic])
  @@index([playCount(sort: Desc)])
  @@index([likeCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([agentId, status])
  @@index([agentId, isPublic])
  @@index([genreId, status])
  @@index([isPublic, status])
  @@index([trendingScore(sort: Desc)])
  @@index([takedownStatus])
  @@index([licenseable])
  @@index([parentTrackId])
  @@map("tracks")
}

model Video {
  id        String  @id @default(cuid())
  videoUrl  String  @map("video_url")
  thumbnail String?
  duration  Int? // video duration in seconds

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trackId String @unique @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@map("videos")
}

// ─── Clips ───────────────────────────────────────────────
//
// User-uploaded short video paired with a Track. The same Track can power
// many Clips (TikTok-style "this sound has 1.2k clips"). Distinct from the
// Video model above which is a 1:1 AI-generated music video bound to a
// Track.
model Clip {
  id     String     @id @default(cuid())
  status ClipStatus @default(PROCESSING)

  // Source upload + processed output. rawVideoUrl/rawPublicId are the
  // user's original Cloudinary upload; videoUrl is the eager-transformed
  // URL with the Track audio overlaid + trimmed to ≤60s.
  rawVideoUrl  String  @map("raw_video_url")
  rawPublicId  String  @map("raw_public_id")
  videoUrl     String  @map("video_url")
  thumbnail    String?

  // All durations in milliseconds. Server-enforced: trimEndMs - trimStartMs ≤ 60000.
  durationMs   Int @map("duration_ms")
  trimStartMs  Int @default(0) @map("trim_start_ms")
  trimEndMs    Int @map("trim_end_ms")
  audioStartMs Int @default(0) @map("audio_start_ms")

  // Visibility + presentation
  visibility ClipVisibility @default(PRIVATE)
  caption    String?
  hashtags   String[]       @default([])

  // Moderation
  takedownStatus   TakedownStatus? @map("takedown_status")
  moderationLabels Json?           @map("moderation_labels")

  // Counters (denormalized like Track)
  viewCount     Int   @default(0) @map("view_count")
  likeCount     Int   @default(0) @map("like_count")
  commentCount  Int   @default(0) @map("comment_count")
  shareCount    Int   @default(0) @map("share_count")
  trendingScore Float @default(0) @map("trending_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Ownership + sound
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  // Social
  likes    ClipLike[]
  comments ClipComment[]
  shares   ClipShare[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([trackId, createdAt(sort: Desc)])
  @@index([status])
  @@index([visibility, status, trendingScore(sort: Desc)])
  @@index([visibility, status, createdAt(sort: Desc)])
  // "Popular clips for this sound" feed query. Without this composite, large
  // tracks (lots of clips) hit a sequential scan + sort.
  @@index([trackId, status, visibility, trendingScore(sort: Desc)])
  @@map("clips")
}

model ClipLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clipId String @map("clip_id")
  clip   Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@unique([userId, clipId])
  @@index([clipId])
  @@map("clip_likes")
}

model ClipComment {
  id      String @id @default(cuid())
  content String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clipId String @map("clip_id")
  clip   Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  parentId String?       @map("parent_id")
  parent   ClipComment?  @relation("ClipCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ClipComment[] @relation("ClipCommentReplies")

  @@index([clipId])
  @@index([userId])
  @@index([parentId])
  @@map("clip_comments")
}

model ClipShare {
  id        String   @id @default(cuid())
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clipId String  @map("clip_id")
  clip   Clip    @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([userId])
  @@map("clip_shares")
}

model Album {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  coverArt    String? @map("cover_art")
  description String?

  releaseDate DateTime? @map("release_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tracks  Track[]

  @@index([agentId])
  @@index([releaseDate(sort: Desc)])
  @@map("albums")
}

// ─── Social Models ───────────────────────────────────────

model Playlist {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  coverArt    String? @map("cover_art")
  isPublic    Boolean @default(true) @map("is_public")

  // Paid playlist (channel subscription) fields
  accessTier        PlaylistAccessTier @default(PUBLIC) @map("access_tier")
  monthlyPriceCents Int?               @map("monthly_price_cents")
  currency          String?            @default("usd")
  stripeProductId   String?            @unique @map("stripe_product_id")
  stripePriceId     String?            @unique @map("stripe_price_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String          @map("user_id")
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  channelSubscriptions ChannelSubscription[]

  @@index([userId])
  @@index([accessTier])
  @@map("playlists")
}

model PlaylistTrack {
  id       String @id @default(cuid())
  position Int // ordering within playlist

  addedAt DateTime @default(now()) @map("added_at")

  playlistId String   @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  trackId    String   @map("track_id")
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([trackId])
  @@index([playlistId, position])
  @@map("playlist_tracks")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([trackId])
  @@index([createdAt(sort: Desc)])
  // Liked-tracks list pages WHERE userId AND ORDER BY createdAt DESC. The
  // single-column userId index is implicit via the unique tuple above (only
  // for prefix scans), so an explicit composite is needed for sort.
  @@index([userId, createdAt(sort: Desc)])
  @@map("likes")
}

model Comment {
  id      String @id @default(cuid())
  content String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  // Self-referencing for threaded comments
  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([trackId])
  @@index([userId])
  @@index([parentId])
  // getComments fetches top-level comments for a track ordered by createdAt
  // DESC; without this the planner has to sort after the trackId scan.
  @@index([trackId, parentId, createdAt(sort: Desc)])
  @@map("comments")
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId  String  @map("user_id")
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([agentId])
  @@map("follows")
}

model Share {
  id        String   @id @default(cuid())
  platform  String? // 'copy', 'twitter', 'facebook', etc.
  createdAt DateTime @default(now()) @map("created_at")

  userId  String? @map("user_id")
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  trackId String  @map("track_id")
  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
  @@map("shares")
}

// One row per (user, track) offline download. Unique tuple keeps re-downloads
// of the same track from inflating the counter — re-downloading is idempotent
// from an engagement-tracking perspective.
model Download {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([trackId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("downloads")
}

// ─── Analytics Models ────────────────────────────────────

model Play {
  id             String   @id @default(cuid())
  durationPlayed Int      @default(0) @map("duration_played") // seconds actually listened
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  userId  String? @map("user_id")
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  trackId String  @map("track_id")
  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
  @@index([createdAt])
  // History endpoint: WHERE userId ORDER BY createdAt DESC LIMIT n. The
  // composite turns it into an index-only range scan.
  @@index([userId, createdAt(sort: Desc)])
  @@map("plays")
}

// ─── Monetization Models ─────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  tier             SubscriptionTier   @default(FREE)
  status           SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?            @unique @map("stripe_customer_id")
  stripeSubId      String?            @unique @map("stripe_sub_id")

  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  // Mirrors Stripe's `cancel_at_period_end` so the UI can show
  // "ending Apr 30" without a Stripe round-trip. Synced on
  // customer.subscription.updated and the cancel endpoint.
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Index renewal/expiry sweep cron queries.
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

// Stripe webhook idempotency. We `create` with the event id at the start
// of webhook handling; the unique constraint makes Stripe's automatic
// retries no-ops without burning provider quota or double-crediting
// referral earnings.
model WebhookEvent {
  id           String   @id @default(cuid())
  stripeEventId String  @unique @map("stripe_event_id")
  eventType    String   @map("event_type")
  processedAt  DateTime @default(now()) @map("processed_at")

  @@index([processedAt(sort: Desc)])
  @@map("webhook_events")
}

model ConnectAccount {
  id               String               @id @default(cuid())
  stripeAccountId  String               @unique @map("stripe_account_id")
  status           ConnectAccountStatus @default(PENDING)
  payoutsEnabled   Boolean              @default(false) @map("payouts_enabled")
  chargesEnabled   Boolean              @default(false) @map("charges_enabled")
  detailsSubmitted Boolean              @default(false) @map("details_submitted")
  country          String?
  defaultCurrency  String?              @default("usd") @map("default_currency")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("connect_accounts")
}

model Tip {
  id                      String    @id @default(cuid())
  amountCents             Int       @map("amount_cents")
  platformFeeCents        Int       @map("platform_fee_cents")
  netCents                Int       @map("net_cents")
  currency                String    @default("usd")
  message                 String?   @db.VarChar(500)
  status                  TipStatus @default(PENDING)
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?   @unique @map("stripe_payment_intent_id")
  stripeTransferId        String?   @unique @map("stripe_transfer_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromUserId String? @map("from_user_id")
  fromUser   User?   @relation("TipsSent", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUserId   String  @map("to_user_id")
  toUser     User    @relation("TipsReceived", fields: [toUserId], references: [id], onDelete: Restrict)
  trackId    String? @map("track_id")
  track      Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)

  @@index([toUserId, createdAt(sort: Desc)])
  @@index([fromUserId])
  @@index([status])
  @@index([trackId])
  @@map("tips")
}

model ChannelSubscription {
  id                   String                    @id @default(cuid())
  amountCents          Int                       @map("amount_cents")
  platformFeeBps       Int                       @map("platform_fee_bps")
  currency             String                    @default("usd")
  status               ChannelSubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String                    @unique @map("stripe_subscription_id")
  stripeCustomerId     String                    @map("stripe_customer_id")
  currentPeriodStart   DateTime?                 @map("current_period_start")
  currentPeriodEnd     DateTime?                 @map("current_period_end")
  cancelAtPeriodEnd    Boolean                   @default(false) @map("cancel_at_period_end")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriberUserId String   @map("subscriber_user_id")
  subscriber       User     @relation("ChannelSubsAsFan", fields: [subscriberUserId], references: [id], onDelete: Cascade)
  creatorUserId    String   @map("creator_user_id")
  creator          User     @relation("ChannelSubsAsCreator", fields: [creatorUserId], references: [id], onDelete: Restrict)
  playlistId       String   @map("playlist_id")
  playlist         Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([subscriberUserId, playlistId])
  @@index([creatorUserId, status])
  @@index([playlistId, status])
  @@index([stripeCustomerId])
  @@map("channel_subscriptions")
}

model AgentEarning {
  id     String @id @default(cuid())
  amount Decimal @default(0) @db.Decimal(12, 2) // earnings in USD (TODO: migrate to Int cents to standardize across money tables)
  plays  Int    @default(0) // plays in this period
  period String // e.g. "2026-02"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, period])
  @@index([agentId])
  @@map("agent_earnings")
}

// ─── Platform Models ─────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String
  read    Boolean          @default(false)
  data    Json? // additional data (trackId, agentId, etc.)

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
  // listNotifications: WHERE userId [AND read=false] ORDER BY createdAt DESC.
  // The combined index covers both the read+unread filter and the sort.
  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model Report {
  id     String       @id @default(cuid())
  reason String
  status ReportStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([trackId])
  @@index([createdAt(sort: Desc)])
  @@map("reports")
}

// ─── AI Generation Models ───────────────────────────────

model MusicGeneration {
  id     String           @id @default(cuid())
  kind   GenerationKind   @default(MUSIC)
  status GenerationStatus @default(PENDING)

  // Input
  title             String?
  prompt            String? @db.Text
  lyrics            String? @db.Text
  genre             String?
  subGenre          String? @map("sub_genre")
  mood              String?
  energy            String?
  vocalStyle        String? @map("vocal_style")
  era               String?
  vibeReference     String? @map("vibe_reference")
  durationSec       Int?    @map("duration_sec")
  isInstrumental    Boolean @default(false) @map("is_instrumental")
  referenceAudioUrl String? @map("reference_audio_url")

  // Provider
  provider        String  @default("minimax")
  providerModel   String? @map("provider_model")
  providerJobId   String? @unique @map("provider_job_id")
  providerTraceId String? @map("provider_trace_id")

  // Output
  audioUrl     String? @map("audio_url")
  coverArt     String? @map("cover_art")
  errorMessage String? @map("error_message") @db.Text

  // Book-keeping
  creditsUsed Int? @map("credits_used")
  // Provider cost in USD cents. Stored at the row level so per-user / per-tier
  // gross-margin reporting doesn't require re-deriving cost from a moving
  // env-var pricing table. Populated when the generation transitions to
  // COMPLETED or FAILED (failed calls still cost the provider).
  providerCostCents Int? @map("provider_cost_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Ownership
  userId  String   @map("user_id")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId String?  @map("agent_id")
  agent   AiAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Optional: linked track if published
  trackId String? @unique @map("track_id")
  track   Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([status])
  @@index([providerJobId])
  @@map("music_generations")
}

model VideoGeneration {
  id     String           @id @default(cuid())
  status GenerationStatus @default(PENDING)
  // "preview" = auto-generated TikTok/Reels clip on publish; the cron
  // poller writes the result URL back to Track.previewVideoUrl. "user"
  // = regular user-initiated video.
  purpose String @default("user")

  // Input
  title       String?
  prompt      String? @db.Text
  imageRefUrl String? @map("image_ref_url") // for image-to-video
  durationSec Int?    @map("duration_sec")
  resolution  String? // e.g. "720p", "1080p"

  // Provider
  provider       String  @default("minimax")
  providerModel  String? @map("provider_model")
  providerJobId  String? @map("provider_job_id")
  providerFileId String? @map("provider_file_id")

  // Output
  videoUrl     String? @map("video_url")
  thumbnail    String?
  errorMessage String? @map("error_message") @db.Text

  creditsUsed Int? @map("credits_used")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Ownership
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional link back to the track this video was generated FOR (used by
  // the auto-preview flow). Distinct from the Video model which is the
  // canonical "music video for this track" relation.
  trackId String? @map("track_id")
  track   Track?  @relation("TrackVideoGenerations", fields: [trackId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([providerJobId])
  @@index([trackId])
  @@index([status, purpose])
  @@map("video_generations")
}

// ─── Collaboration ──────────────────────────────────────

// Multi-agent tracks. Each collaborator has a basis-points share of earnings
// (sum across collaborators must total 10000 = 100%). Stripe transfers split
// tip / sub / sync earnings proportionally on payout.
model TrackCollaborator {
  id        String   @id @default(cuid())
  shareBps  Int      @map("share_bps")
  role      String? // optional label e.g. "feature", "producer"
  createdAt DateTime @default(now()) @map("created_at")

  trackId String  @map("track_id")
  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  agentId String  @map("agent_id")
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([trackId, agentId])
  @@index([agentId])
  @@map("track_collaborators")
}

// ─── Stems ──────────────────────────────────────────────

// One row per track holding the URLs of the four classic Demucs/Spleeter
// stems. Generated asynchronously after the track is published. Sold as a
// paid bundle if `forSaleCents` is non-null.
model TrackStems {
  id            String     @id @default(cuid())
  status        StemStatus @default(PENDING)
  drumsUrl      String?    @map("drums_url")
  bassUrl       String?    @map("bass_url")
  vocalsUrl     String?    @map("vocals_url")
  otherUrl      String?    @map("other_url")
  provider      String? // e.g. "replicate-demucs"
  providerJobId String?    @map("provider_job_id")
  errorMessage  String?    @map("error_message") @db.Text

  // Owner pays a flat fee to generate stems. Tracked per-row for idempotency
  // in the webhook and as an audit trail.
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  paidAmountCents         Int?      @map("paid_amount_cents")
  paidAt                  DateTime? @map("paid_at")

  forSaleCents Int?    @map("for_sale_cents")
  currency     String? @default("usd")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trackId String @unique @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("track_stems")
}

// ─── DMCA / Takedowns ───────────────────────────────────

// User-submitted DMCA / copyright complaint. The track is hidden the moment
// the takedown is filed (status=PENDING) and only fully removed if accepted
// by an admin. Withdrawn or rejected takedowns restore visibility.
model Takedown {
  id            String         @id @default(cuid())
  status        TakedownStatus @default(PENDING)
  reason        String         @db.Text
  claimantName  String         @map("claimant_name")
  claimantEmail String         @map("claimant_email")
  evidenceUrl   String?        @map("evidence_url")
  adminNotes    String?        @map("admin_notes") @db.Text

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  // Submitter is optional — DMCA forms accept anonymous-ish claims by email.
  submitterId String? @map("submitter_id")
  submitter   User?   @relation(fields: [submitterId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([trackId])
  @@index([submitterId])
  @@index([createdAt(sort: Desc)])
  @@map("takedowns")
}

// ─── Sync Licensing ─────────────────────────────────────

// One row per purchased commercial-use license. Buyer downloads a clean WAV
// and a license PDF. Platform takes a fixed bps cut, the rest is transferred
// to the agent owner via Stripe Connect.
model SyncLicense {
  id                      String            @id @default(cuid())
  status                  SyncLicenseStatus @default(PENDING)
  amountCents             Int               @map("amount_cents")
  platformFeeCents        Int               @map("platform_fee_cents")
  netCents                Int               @map("net_cents")
  currency                String            @default("usd")
  licenseTier             String            @default("standard") @map("license_tier")
  buyerEmail              String?           @map("buyer_email")
  buyerName               String?           @map("buyer_name")
  intendedUse             String?           @map("intended_use")
  stripeCheckoutSessionId String?           @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?           @unique @map("stripe_payment_intent_id")
  stripeTransferId        String?           @unique @map("stripe_transfer_id")
  licensePdfUrl           String?           @map("license_pdf_url")
  downloadToken           String?           @unique @map("download_token")
  downloadExpiresAt       DateTime?         @map("download_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trackId String  @map("track_id")
  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  buyerId String? @map("buyer_id")
  buyer   User?   @relation("SyncLicensePurchaser", fields: [buyerId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([buyerId])
  @@index([status])
  @@index([stripeTransferId])
  @@map("sync_licenses")
}

// ─── Distribution (Spotify/Apple via DistroKid/TuneCore) ─

// Tracks the state of an external distribution job. Concrete API integration
// is gated on a partnership; this model lets us collect demand, queue
// requests, and surface status to creators.
model TrackDistribution {
  id           String             @id @default(cuid())
  status       DistributionStatus @default(PENDING)
  partner      String // "distrokid" | "tunecore" | "manual"
  partnerJobId String?            @map("partner_job_id")
  upc          String? @unique // Universal Product Code if assigned
  isrc         String? @unique // International Standard Recording Code
  releaseDate  DateTime?          @map("release_date")
  takedownAt   DateTime?          @map("takedown_at")
  errorMessage String?            @map("error_message") @db.Text

  // Wizard fields persisted from the creator-facing distribute form. Required
  // by every partner API; we collect them up-front so an admin / partner job
  // doesn't have to chase the creator for missing metadata.
  releaseTitle  String?  @map("release_title")
  artistName    String?  @map("artist_name")
  // Free-form metadata: { primaryGenre, language, explicit, songwriters[], contributors[] }.
  // Partner APIs disagree on the exact shape, so we store the wizard payload
  // as-is and translate at submission time.
  metadata      Json?
  // Admin notes attached during the manual-partner flow (e.g. "submitted via
  // DistroKid web UI, ETA 48h"). Visible to admins only.
  partnerNotes  String?  @map("partner_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trackId String @map("track_id")
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([trackId])
  @@index([partnerJobId])
  @@map("track_distributions")
}

// ─── Referrals ──────────────────────────────────────────

// Recorded each time a referee earns money (tip received, channel-sub charge,
// sync license sold). The referrer's cut is queued for payout via Stripe
// Connect by a separate cron job.
model ReferralEarning {
  id               String  @id @default(cuid())
  amountCents      Int     @map("amount_cents")
  currency         String  @default("usd")
  source           String // "tip" | "channel_sub" | "sync_license"
  sourceId         String  @map("source_id") // id of the originating row
  paidOut          Boolean @default(false) @map("paid_out")
  stripeTransferId String? @map("stripe_transfer_id")

  createdAt DateTime @default(now()) @map("created_at")

  referrerId String @map("referrer_id")
  // Restrict — deleting a referrer would otherwise wipe owed-money rows.
  // Force the deletion path to settle outstanding referrals first.
  referrer   User   @relation("ReferralEarningReferrer", fields: [referrerId], references: [id], onDelete: Restrict)
  // The referee who actually generated the earning. Tracked separately so we
  // can query "how much have I earned from each referral".
  refereeId  String @map("referee_id")
  referee    User   @relation("ReferralEarningSource", fields: [refereeId], references: [id], onDelete: Cascade)

  // Prevent double-credit: webhook retries with the same source/sourceId
  // will collide on this constraint instead of creating duplicate earnings.
  @@unique([source, sourceId, referrerId])
  // The unique constraint above already creates a usable index for the
  // (source, sourceId) prefix; a separate @@index would be redundant.
  @@index([referrerId, paidOut])
  @@index([refereeId])
  @@index([createdAt(sort: Desc)])
  @@map("referral_earnings")
}

// ─── Collaboration payouts ─────────────────────────────
//
// One row per (source, sourceId, ownerUserId). Represents a single Stripe
// Connect transfer obligation: when a track with multiple collaborators
// generates earnings (tip / license), each collaborator's share is recorded
// here and paid out asynchronously. The transfer originates from the primary
// agent owner's connect account (where destination charges land), so we
// transfer ON BEHALF OF that account to the collaborator's account.

model CollabPayout {
  id               String       @id @default(cuid())
  source           String // "tip" | "sync_license"
  sourceId         String       @map("source_id")
  trackId          String       @map("track_id")
  track            Track        @relation(fields: [trackId], references: [id], onDelete: Restrict)
  fromUserId       String       @map("from_user_id") // primary owner whose account funds the transfer
  fromUser         User         @relation("CollabPayoutsFrom", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUserId         String       @map("to_user_id") // collaborator owner receiving the transfer
  toUser           User         @relation("CollabPayoutsTo", fields: [toUserId], references: [id], onDelete: Restrict)
  shareBps         Int          @map("share_bps")
  amountCents      Int          @map("amount_cents")
  currency         String       @default("usd")
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @unique @map("stripe_transfer_id")
  errorMessage     String?      @map("error_message")
  attempts         Int          @default(0)

  createdAt DateTime  @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  // Idempotency: webhook replay must not create duplicate transfers.
  @@unique([source, sourceId, toUserId])
  @@index([status, createdAt])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([trackId])
  @@map("collab_payouts")
}

// ─── Public API ─────────────────────────────────────────

// API key for the public developer API. Hashed at rest (sha-256 of the raw
// key); the raw key is shown to the user once at creation and never stored.
model ApiKey {
  id              String    @id @default(cuid())
  name            String
  prefix          String // first 8 chars of the raw key for UI display
  keyHash         String    @unique @map("key_hash")
  scopes          String[]  @default([])
  lastUsedAt      DateTime? @map("last_used_at")
  revokedAt       DateTime? @map("revoked_at")
  rateLimitPerMin Int       @default(60) @map("rate_limit_per_min")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// ─── Mixtapes ───────────────────────────────────────────

// Generated weekly per active user. Stores the source playlist id + an
// idempotency key (period) so we never generate twice for the same week.
model UserMixtape {
  id         String    @id @default(cuid())
  period     String // ISO week, e.g. "2026-W18"
  playlistId String    @map("playlist_id")
  emailedAt  DateTime? @map("emailed_at")
  pushedAt   DateTime? @map("pushed_at")

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([playlistId])
  @@map("user_mixtapes")
}

// ─── Listening parties ──────────────────────────────────
//
// Real-time synchronized playback room. Host writes are authoritative and
// broadcast over Socket.IO `/parties` namespace; members receive `state`
// events and locally interpolate playhead. Server only persists snapshot
// every ~30s to avoid hammering the DB.

model ListeningParty {
  id         String               @id @default(cuid())
  // Short shareable code (6-char base32). The party URL is /party/<code>.
  code       String               @unique
  status     ListeningPartyStatus @default(ACTIVE)
  // Last-known playhead and play state. Members trust the latest broadcast
  // tick; this row is a snapshot for joiners arriving mid-session.
  positionMs Int                  @default(0) @map("position_ms")
  isPlaying  Boolean              @default(false) @map("is_playing")
  // Last time we saw a host:tick. The cron sweep ends parties whose host
  // has been silent for 30+ min.
  lastTickAt DateTime             @default(now()) @map("last_tick_at")
  startedAt  DateTime             @default(now()) @map("started_at")
  endedAt    DateTime?            @map("ended_at")

  hostUserId String @map("host_user_id")
  host       User   @relation("PartiesHosted", fields: [hostUserId], references: [id], onDelete: Cascade)

  trackId String? @map("track_id")
  track   Track?  @relation("PartyCurrentTrack", fields: [trackId], references: [id], onDelete: SetNull)

  members ListeningPartyMember[]

  @@index([code])
  @@index([hostUserId, status])
  @@index([status, lastTickAt])
  @@map("listening_parties")
}

model ListeningPartyMember {
  id       String         @id @default(cuid())
  partyId  String         @map("party_id")
  party    ListeningParty @relation(fields: [partyId], references: [id], onDelete: Cascade)

  // Either userId (logged-in joiner) or guestKey (anon visitor identified
  // by signed cookie). Exactly one will be non-null. Composite unique
  // constraints below enforce one row per (party, user) and one per
  // (party, guest cookie).
  userId   String? @map("user_id")
  user     User?   @relation("PartyMembers", fields: [userId], references: [id], onDelete: SetNull)
  guestKey String? @map("guest_key")

  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  @@unique([partyId, userId])
  @@unique([partyId, guestKey])
  @@index([partyId])
  @@map("listening_party_members")
}

// ─── Marketplace ────────────────────────────────────────
//
// Sample packs (audio bundles) and prompt presets (saved generation
// configurations) sold by creators. Stripe Connect transfer to seller's
// account on purchase, idempotent on WebhookEvent. Pattern lifted from
// SyncLicense.

model MarketplaceListing {
  id          String                   @id @default(cuid())
  type        MarketplaceListingType
  status      MarketplaceListingStatus @default(DRAFT)
  slug        String                   @unique
  title       String
  description String?                  @db.Text
  coverArt    String?                  @map("cover_art")

  priceCents Int    @map("price_cents")
  currency   String @default("usd")

  // Sample-pack assets: array of Cloudinary URLs pointing at audio files
  // (or a single zip URL). Empty for PROMPT_PRESET listings.
  assetUrls      String[] @default([]) @map("asset_urls")
  // Optional 30s preview snippet — public, used for the listing page.
  sampleAudioUrl String?  @map("sample_audio_url")

  // Prompt-preset payload: { idea, genre, mood, energy, era, vocalStyle,
  // vibeReference, isInstrumental, ... } — whatever the create wizard reads.
  // Empty for SAMPLE_PACK listings.
  presetData Json? @map("preset_data")

  // Stripe — created lazily on first checkout (mirrors Playlist channel-sub
  // pattern).
  stripeProductId String? @unique @map("stripe_product_id")
  stripePriceId   String? @unique @map("stripe_price_id")

  // Denormalized stats
  purchaseCount Int @default(0) @map("purchase_count")
  viewCount     Int @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerUserId String @map("seller_user_id")
  seller       User   @relation("MarketplaceListings", fields: [sellerUserId], references: [id], onDelete: Cascade)

  purchases MarketplacePurchase[]

  @@index([type, status])
  @@index([sellerUserId])
  @@index([status, createdAt(sort: Desc)])
  @@map("marketplace_listings")
}

model MarketplacePurchase {
  id               String                    @id @default(cuid())
  status           MarketplacePurchaseStatus @default(PENDING)
  amountCents      Int                       @map("amount_cents")
  platformFeeCents Int                       @map("platform_fee_cents")
  netCents         Int                       @map("net_cents")
  currency         String                    @default("usd")

  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @unique @map("stripe_payment_intent_id")
  stripeTransferId        String? @unique @map("stripe_transfer_id")

  // Time-limited download token mirroring SyncLicense pattern.
  downloadToken     String?   @unique @map("download_token")
  downloadExpiresAt DateTime? @map("download_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listingId String             @map("listing_id")
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  buyerUserId String @map("buyer_user_id")
  buyer       User   @relation("MarketplacePurchases", fields: [buyerUserId], references: [id], onDelete: Cascade)

  @@index([buyerUserId])
  @@index([listingId])
  @@index([status])
  @@map("marketplace_purchases")
}

// ─── DJ sessions (real-time AI improv mix) ─────────────
//
// A DjSession is a continuous, host-driven AI mix. The host's vibe input
// seeds the next generation; as the current track approaches end, the
// server promotes the queued track and kicks off the generation for the
// slot after that. Members listen via the /dj Socket.IO namespace.

model DjSession {
  id          String          @id @default(cuid())
  // Shareable 6-char code (same alphabet as ListeningParty).
  code        String          @unique
  status      DjSessionStatus @default(LIVE)
  // Free-form vibe direction, e.g. "deep house, 122bpm, peak time energy".
  // The next generation seeds from this. Hosts can update it mid-session
  // and the change shows up on the NEXT generation, not the current one.
  currentVibe String?         @db.Text @map("current_vibe")
  // Position pointers into the dj_session_tracks table. currentTrackId is the
  // playing slot; nextTrackId is the buffered slot. Both nullable while a
  // session is just starting.
  currentTrackId String?      @map("current_track_id")
  nextTrackId    String?      @map("next_track_id")
  startedAt      DateTime     @default(now()) @map("started_at")
  endedAt        DateTime?    @map("ended_at")
  // Heartbeat: cron sweep ends sessions whose host has been silent for
  // 30+ min. Mirrors the listening-party pattern.
  lastTickAt     DateTime     @default(now()) @map("last_tick_at")

  hostUserId String @map("host_user_id")
  host       User   @relation("DjSessionsHosted", fields: [hostUserId], references: [id], onDelete: Cascade)

  tracks DjSessionTrack[]

  @@index([code])
  @@index([hostUserId, status])
  @@index([status, lastTickAt])
  @@map("dj_sessions")
}

model DjSessionTrack {
  id        String    @id @default(cuid())
  sessionId String    @map("session_id")
  session   DjSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Each slot eventually points at a MusicGeneration row whose audio plays
  // for that slot. Nullable while the generation is pending — we record the
  // slot before audio finishes so position math stays stable.
  generationId String? @map("generation_id")
  // The vibe that seeded this slot. Captured at slot-creation time so a
  // mid-session vibe change doesn't rewrite history.
  vibePrompt String   @db.Text @map("vibe_prompt")
  position   Int
  playedAt   DateTime? @map("played_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([sessionId, position])
  @@index([sessionId, position])
  @@map("dj_session_tracks")
}

// ─── OAuth apps (developer marketplace) ──────────────────
//
// Third-party developers register an OAuth app. End users grant the app
// scoped access via /oauth/authorize → /oauth/token (PKCE auth-code flow).
// The resulting OAuthGrant carries an access token that downstream
// /api/v1/* endpoints accept alongside the existing ApiKey bearer.

model OAuthApp {
  id           String         @id @default(cuid())
  // Public client identifier — appears in OAuth requests.
  clientId     String         @unique @map("client_id")
  // SHA-256 hash of the raw client secret. Raw shown ONCE at creation,
  // never persisted or echoed.
  clientSecretHash String     @unique @map("client_secret_hash")

  name         String
  slug         String         @unique
  description  String?        @db.Text
  iconUrl      String?        @map("icon_url")
  homepage     String?

  // Redirect URIs the app can specify in /oauth/authorize. Strict match.
  redirectUris String[]       @default([]) @map("redirect_uris")

  // Scopes the app is allowed to request from users. Subset of
  // ALLOWED_SCOPES from apiKeyController. Editing this resets status to
  // PENDING.
  scopes       String[]       @default([])

  status       OAuthAppStatus @default(PENDING)
  // Whether the app shows in the public /developers/apps registry. Admin
  // sets this independently of status — an APPROVED app may still be
  // unlisted (private integration).
  listed       Boolean        @default(false)

  ownerUserId  String         @map("owner_user_id")
  owner        User           @relation("OAuthAppsOwned", fields: [ownerUserId], references: [id], onDelete: Cascade)

  grants       OAuthGrant[]

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([ownerUserId])
  @@index([status, listed])
  @@map("oauth_apps")
}

model OAuthGrant {
  id     String   @id @default(cuid())
  appId  String   @map("app_id")
  app    OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  userId String   @map("user_id")
  user   User     @relation("OAuthGrantsAuthorized", fields: [userId], references: [id], onDelete: Cascade)

  scopes String[] @default([])

  // Authorization code (short-lived, single-use). Stored hashed; raw
  // delivered to the redirect URI. Cleared on token exchange.
  codeHash      String?   @unique @map("code_hash")
  codeExpiresAt DateTime? @map("code_expires_at")
  // PKCE: validated against code_verifier on token exchange. S256 only
  // (we reject `plain`).
  codeChallenge       String? @map("code_challenge")
  codeChallengeMethod String? @map("code_challenge_method")
  // The redirect_uri the app sent at /authorize — must match at /token.
  redirectUri         String? @map("redirect_uri")

  // Long-lived (90-day) access token, hashed at rest.
  accessTokenHash      String?   @unique @map("access_token_hash")
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")

  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime  @default(now()) @map("created_at")

  // One grant per (app, user) — re-authorizing replaces the prior grant
  // rather than stacking duplicates.
  @@unique([appId, userId])
  @@index([userId])
  @@map("oauth_grants")
}

// ─── Discord integration ────────────────────────────────
//
// Maps a Discord user to their MakeYourMusic account. Until linked, the
// bot serves /music commands using a shared low-rate-limit ApiKey
// (DISCORD_FREE_API_KEY_ID). Once linked, generations bill the linked
// user via their personal API key.
model DiscordIntegration {
  id            String  @id @default(cuid())
  discordUserId String  @unique @map("discord_user_id")
  // 6-char base32 link code shown in Discord; the user pastes this into
  // /settings/discord to bind. Cleared once bound (userId set).
  linkCode      String? @unique @map("link_code")
  linkExpires   DateTime? @map("link_expires")

  userId String? @map("user_id")
  user   User?   @relation("DiscordIntegrations", fields: [userId], references: [id], onDelete: SetNull)

  apiKeyId String? @map("api_key_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([linkCode])
  @@map("discord_integrations")
}
